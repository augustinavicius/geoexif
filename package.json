{
  "name": "geoexif",
  "version": "0.0.2",
  "description": "Fast photo EXIF geolocation viewer.",
  "main": "app.js",
  "scripts": {
    "dev": "electron .",
    "clean": "modclean",
    "build": "modclean && electron-builder build --win --publish never",
    "deploy": "modclean && electron-builder build --win --publish always",
    "sass-build": "node-sass --omit-source-map-url styledefs.scss src/styles/bulma.css"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/augustinavicius/geoexif"
  },
  "author": "Ignas Augustinavičius",
  "license": "UNLICENSED",
  "devDependencies": {
    "bulma": "^0.9.4",
    "electron": "^19.0.3",
    "electron-builder": "^23.0.3",
    "modclean": "^3.0.0-beta.1",
    "node-sass": "^7.0.1"
  },
  "dependencies": {
    "custom-electron-titlebar": "^4.1.0",
    "electron-updater": "^5.0.1",
    "leaflet": "^1.8.0"
  },
  "build": {
    "productName": "GEOEXIF",
    "compression": "maximum",
    "win": {
      "publish": [
        "github"
      ],
      "publisherName": "Ignas Augustinavicius"
    },
    "nsis": {
      "oneClick": "false",
      "allowToChangeInstallationDirectory": "true"
    },
    "directories": {
      "buildResources": "buildResources",
      "output": "release"
    }
  }
}
